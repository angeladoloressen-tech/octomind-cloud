{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/money_os/audit_page.html" },
    { "source": "/audit", "destination": "/money_os/audit_page.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
